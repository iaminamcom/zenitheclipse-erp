# Zenith Eclipse ERP Docker/Dokploy environment
# Copy this file to .env before local docker compose runs.

TZ=Asia/Dubai
ZENITH_ERP_DOCKER=1
ZENITH_ERP_HEADLESS=1
ZENITH_ERP_URL_HOST=localhost

# Local-only direct port mapping used by docker-compose.local.yml
APP_PORT=8080

# For production QR codes, set this inside ERP Settings > Company Profile:
# Verification Base URL = https://erp.yourdomain.com/verify
